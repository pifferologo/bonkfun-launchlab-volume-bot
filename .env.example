# ElevenLabs Scribe API key (required for transcription)
ELEVENLABS_API_KEY=

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Redis (optional — transcript caching across sessions)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=video-use:
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_MAX_RETRIES=5
REDIS_DEFAULT_TTL_SECONDS=86400
